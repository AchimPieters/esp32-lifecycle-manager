CompileFlags:
  Remove:
    # RISC-V / Xtensa GCC flags not understood by host clang
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -fno-jump-tables
    - -march=rv32imc*
    - -march=xtensa*
    - -mabi=*
    - -misa-spec=*
    - -mfix-esp32-psram-cache-issue
    - -mfix-esp32-psram-cache-strategy=*
    - -nostartfiles
    - --param=*
    - -fdiagnostics-color=*
    - -Werror=all
    - -Wno-old-style-declaration
    - -Wno-enum-conversion
  Add:
    - -ferror-limit=0
    - -Wno-unknown-warning-option

Diagnostics:
  Suppress:
    # All of the following fire only because ESP-IDF headers are absent on
    # the host machine. They are not real errors; a proper compile_commands.json
    # from "idf.py build" suppresses them at the source.
    - pp_file_not_found
    - unknown_typename
    - undeclared_var_use
    - undeclared_var_use_suggest
    - drv_unknown_argument
    - drv_unsupported_option_argument
    - Wimplicit-function-declaration
    - implicit_func_decl_warn
  ClangTidy:
    Remove:
      - '*'
